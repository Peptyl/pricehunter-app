# PriceHunter Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# API SERVER
# ============================================================================
PORT=8000
ENV=development
DEV_MODE=false

# ============================================================================
# FIREBASE
# ============================================================================
FIREBASE_API_KEY=AIzaSyDUFIFFPRLhUy2IfT5BDCKqbZsGphYWL2Y
FIREBASE_SERVICE_ACCOUNT_JSON=
# Set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON content of your Firebase service account key
# Or place service-account.json at ~/.config/firebase/service-account.json

# ============================================================================
# CLERK AUTHENTICATION
# ============================================================================
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
CLERK_JWT_KEY=https://clerk.openclaw.dev/.well-known/jwks.json

# ============================================================================
# REVENUECAT (SUBSCRIPTIONS)
# ============================================================================
REVENUECAT_API_KEY=sk_funIsfnYUqsOUzcVbQmHwncNpqBQw
REVENUECAT_PROJECT_ID=proj_funIsfnYUqsOUzcVbQmHwncNpqBQw

# ============================================================================
# POSTGRESQL DATABASE
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pricehunter
DB_USER=pricehunter
DB_PASS=pricehunter123

# ============================================================================
# REDIS (CACHING)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# SCRAPER CONFIGURATION
# ============================================================================
SCRAPER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_PROXY_ENABLED=false
PROXY_LIST=

# ============================================================================
# SCHEDULER
# ============================================================================
SCHEDULER_ENABLED=true
SCHEDULER_SCAN_TIMES=06:00,12:00,18:00
SCHEDULER_TIMEZONE=UTC

# ============================================================================
# NOTIFICATIONS
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHANNEL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@pricehunter.app

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/tmp/pricehunter.log
