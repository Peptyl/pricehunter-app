# ============================================================================
# Olfex (formerly PriceHunter) - Production Configuration
# ============================================================================
# Copy this file to .env and update with actual values
# NEVER commit .env to version control

# ============================================================================
# Application Environment
# ============================================================================
OLFEX_ENV=production
LOG_LEVEL=INFO
DEBUG=false

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL credentials - MUST be changed in production
DB_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://olfex:${DB_PASSWORD}@localhost:5432/olfex

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# API Server Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# ============================================================================
# Domain Configuration
# ============================================================================
API_DOMAIN=api.olfex.app
FRONTEND_DOMAIN=olfex.app
FRONTEND_URL=https://olfex.app

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://olfex.app,https://www.olfex.app

# ============================================================================
# Proxy Configuration for Web Scraping
# ============================================================================
# Residential proxy provider for scraping (e.g., brightdata, oxylabs, smartproxy)
PROXY_PROVIDER=brightdata
PROXY_API_KEY=your_proxy_api_key_here

# Fallback proxy URL (optional)
# PROXY_URL=http://user:pass@proxy.example.com:8080

# ============================================================================
# Scraper Configuration
# ============================================================================
# Maximum concurrent browser instances
MAX_CONCURRENT_BROWSERS=3

# Scraper timeout settings (seconds)
BROWSER_TIMEOUT=30
NAVIGATION_TIMEOUT=15
WAIT_TIMEOUT=10

# User agent for requests
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ============================================================================
# Scheduler Configuration
# ============================================================================
# Scan schedule (24-hour format, comma-separated)
SCAN_TIMES=06:00,18:00

# Timezone for scheduling
TIMEZONE=Europe/London

# ============================================================================
# Notifications & Webhooks
# ============================================================================
# Slack integration for alerts and notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_ADDRESS=noreply@olfex.app

# ============================================================================
# Authentication & Security
# ============================================================================
# Supabase configuration for user management
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# JWT Secret for API tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your_secret_key_here_change_in_production

# Session configuration
SESSION_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# Data Retention & Cleanup
# ============================================================================
# Delete price scans older than N days (0 = never delete)
PRICE_SCAN_RETENTION_DAYS=730

# Delete scan cycle logs older than N days
SCAN_CYCLE_LOG_RETENTION_DAYS=90

# ============================================================================
# Rate Limiting
# ============================================================================
# Requests per minute for API endpoints
API_RATE_LIMIT_RPM=60

# Requests per minute for search endpoints
SEARCH_RATE_LIMIT_RPM=30

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_PRICE_ALERTS=true
FEATURE_FAVORITES=true
FEATURE_PRICE_HISTORY=true
FEATURE_COMPETITOR_TRACKING=true

# ============================================================================
# Monitoring & Observability
# ============================================================================
# Sentry for error tracking
SENTRY_DSN=

# Application metrics (Prometheus, StatsD, etc.)
METRICS_ENABLED=false
METRICS_PORT=8001

# ============================================================================
# Development/Testing Only (DO NOT USE IN PRODUCTION)
# ============================================================================
# SEED_TEST_DATA=false
# MOCK_SCRAPER=false
